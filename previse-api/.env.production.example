# =====================================================================
# Previse v2 — éles (production) környezeti változók sablon
# =====================================================================
# CPanel telepítéshez. A sárga megjelölésű részeket KÖTELEZŐ kitölteni.
# Másold át .env-be a szerveren, NE commitold a tényleges értékekkel!
# =====================================================================

APP_NAME=Previse
APP_ENV=production
APP_KEY=                                # ← php artisan key:generate után másold ide
APP_DEBUG=false
APP_URL=https://example.hu              # ← saját domained
FRONTEND_URL=https://example.hu         # ← ugyanaz, ha azonos domain alól megy az SPA

APP_TIMEZONE=Europe/Budapest
APP_LOCALE=hu
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=hu_HU

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

# --- Logolás (file driver, napi rotáció) ---
LOG_CHANNEL=daily
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# --- Adatbázis (CPanel MySQL) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=                            # ← CPanel-ben létrehozott DB neve
DB_USERNAME=                            # ← CPanel DB user
DB_PASSWORD=                            # ← CPanel DB jelszó

# --- Session / Cache / Queue (CPanel-en file driver, mert nincs Redis) ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.example.hu              # ← cseréld a saját domainre (vezető pont fontos)
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=file
CACHE_PREFIX=previse_prod

# --- Email (éles SMTP) ---
# Példa: Gmail App Password / SendGrid / Postmark / saját CPanel SMTP
MAIL_MAILER=smtp
MAIL_SCHEME=                            # vagy "ssl" (465-ös portnál) / "tls" (587-es portnál)
MAIL_HOST=smtp.example.hu               # ← SMTP szerver
MAIL_PORT=587                           # 465 (SSL) vagy 587 (STARTTLS)
MAIL_USERNAME=                          # ← SMTP felhasználónév
MAIL_PASSWORD=                          # ← SMTP jelszó
MAIL_FROM_ADDRESS="noreply@example.hu"  # ← küldő email cím (ugyanaz a domain)
MAIL_FROM_NAME="${APP_NAME}"

# --- Sanctum (SPA stateful auth) ---
# Vesszővel elválasztott domain-lista, ahonnan az SPA-t fogadjuk
SANCTUM_STATEFUL_DOMAINS=example.hu

# --- Auth: meghívó/grace lejáratok (alapértékek) ---
AUTH_INVITATION_EXPIRES_DAYS=7
AUTH_EMAIL_CHANGE_EXPIRES_MINUTES=60
AUTH_ACCOUNT_DELETION_GRACE_DAYS=30
AUTH_EVENTS_RETENTION_DAYS=90

# --- Vite ---
VITE_APP_NAME="${APP_NAME}"
